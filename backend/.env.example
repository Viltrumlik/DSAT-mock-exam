# Backend environment variables
# Copy this file to .env and fill in real values

# ── Django Core ────────────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=your-secret-key-here

# Set to False in production!
DEBUG=False

# Comma-separated list of allowed hostnames (include every console subdomain)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,admin.yourdomain.com,questions.yourdomain.com,teacher.yourdomain.com

# ── HTTPS / Security (recommended in production) ──────────────────────────────
# Enable only after confirming HTTPS works correctly.
ENABLE_HSTS=False
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=False
# SECURE_HSTS_PRELOAD=False

# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL in production (required when DEBUG=False)
# Local dev can omit DATABASE_URL and use SQLite fallback.
DATABASE_URL=postgres://lms_mastersat_user:change-me@127.0.0.1:5432/lms_mastersat_db
DB_SSL=False
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Telegram Login (@BotFather → bot token; Bot Settings → Web Login → Allowed URLs for your site).
# The site widget can request a verified phone; users must approve. Same bot token verifies the payload.
TELEGRAM_BOT_TOKEN=
# Optional: bot username without @. If unset, the API calls Telegram getMe (cached) to show the login button.
# TELEGRAM_BOT_USERNAME=YourBotName
# Optional: synthetic email host for tg{id}@... (default telegram.mastersat.local)
# TELEGRAM_SYNTHETIC_EMAIL_DOMAIN=telegram.mastersat.local

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# ── Email verification (Mailgun) ───────────────────────────────────────────────
# Delivery is inert until EMAIL_BACKEND is set; codes are logged in DEBUG instead.
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=mg.mastersat.uz
# Optional: US region default. EU accounts use https://api.eu.mailgun.net/v3
# MAILGUN_API_BASE=https://api.mailgun.net/v3
# DEFAULT_FROM_EMAIL=MasterSAT <noreply@mg.mastersat.uz>
# NOTE: setting DEFAULT_FROM_EMAIL also wakes the dormant ops-alert senders in
# classes/alerting.py and assessments/ops_alerts.py — check CLASSROOM_OPS_EMAIL_RECIPIENTS first.

# Move an unverified address to whoever proves control of it. Default False; read the
# guards in users/email_verification.py before enabling.
# EMAIL_TRANSFER_ENABLED=False

# Throttles: per target mailbox, per requesting account, per confirm attempt.
# EMAIL_VERIFY_TARGET_THROTTLE=5/hour
# EMAIL_VERIFY_USER_THROTTLE=10/hour
# EMAIL_VERIFY_CONFIRM_THROTTLE=20/hour
# Public self-registration cap (per IP).
# REGISTER_THROTTLE=10/hour
