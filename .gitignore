# ============================================================
# .gitignore — Root project level
# ============================================================

# ── Python / Django ────────────────────────────────────────────
backend/.env
backend/venv/
backend/.venv/
backend/__pycache__/
backend/**/__pycache__/
backend/**/*.pyc
backend/db.sqlite3
backend/staticfiles/
backend/media/

# Deploy shim: optional local npm lock only (deploy.sh uses frontend/ for npm ci)
deploy/package-lock.json

# Server-side PostgreSQL dumps (do not git-track or stash away with `stash -u`)
backups/

# ── Node / Next.js ────────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/.env
frontend/.env.local

# ── OS / Editor ───────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/
backend/dev.sqlite3

# UAT scratch DB (built from model state)
backend/uat.sqlite3

# Local tooling / generated artifacts
.claude/
graphify-out/
test-results/
email_previews/
